// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js required tables ──────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Module 1: User Management ────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          Role      @default(USER)
  passwordHash  String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts         Account[]
  sessions         Session[]
  competitionUsers CompetitionMember[]
  predictions      Prediction[]
  specialAnswers   SpecialAnswer[]
  dartsPlayer      DartsPlayer?
  challengesSent   DartsChallenge[]    @relation("Challenger")
  challengesRecv   DartsChallenge[]    @relation("Opponent")
  dartsMatchesA    DartsMatch[]        @relation("PlayerA")
  dartsMatchesB    DartsMatch[]        @relation("PlayerB")
  dartsWins        DartsMatch[]        @relation("Winner")
  dartsSubmitted   DartsMatch[]        @relation("MatchSubmitter")
}

// ─── Module 2: Sports Predictions ─────────────────────────────────────────────

// Global participant pool — shared across competitions
enum ParticipantType {
  PLAYER
  COUNTRY
  TEAM
}

model Participant {
  id          String          @id @default(cuid())
  name        String                          // Display name (e.g. "Luke Littler", "Deutschland")
  shortName   String?
  type        ParticipantType
  imageUrl    String?
  firstName   String?
  lastName    String?
  nickname    String?
  worldRank   Int?
  country     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  homeFixtures       Fixture[]        @relation("HomeParticipant")
  awayFixtures       Fixture[]        @relation("AwayParticipant")
  specialAnswersSingle SpecialAnswer[] @relation("SingleParticipantAnswer")
}

enum CompetitionStatus {
  ACTIVE
  FINISHED
  ARCHIVED
}

model Competition {
  id               String            @id @default(cuid())
  name             String
  sport            String
  description      String?           @db.Text
  startDate        DateTime
  endDate          DateTime?
  status           CompetitionStatus @default(ACTIVE)
  participantType  ParticipantType   @default(TEAM)
  createdById      String
  createdAt        DateTime          @default(now())

  members          CompetitionMember[]
  fixtures         Fixture[]
  rounds           CompetitionRound[]
  scoringRules     ScoringRule[]
  specialQuestions SpecialQuestion[]
}

model CompetitionMember {
  competitionId String
  userId        String

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([competitionId, userId])
}

// How a match result is expressed and validated
enum MatchFormat {
  SCORE        // Any integer score, draws allowed (football, hockey)
  SETS         // First to N sets/legs, no draw (darts, tennis)
  WINNER_ONLY  // Just pick the winner (e.g. knockout bracket)
}

// A round/phase within a competition (group stage, QF, SF, …)
model CompetitionRound {
  id            String      @id @default(cuid())
  competitionId String
  name          String      // e.g. "Gruppenphase", "Viertelfinale"
  order         Int         // Sort order for display
  matchFormat   MatchFormat @default(SCORE)
  setsToWin     Int?        // For SETS format: how many sets needed to win (e.g. 3)
  pointsExact   Int         @default(3)
  pointsWinner  Int         @default(1)
  pointsDraw    Int         @default(2) // Only relevant for SCORE format

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  fixtures    Fixture[]
}

enum FixtureStatus {
  SCHEDULED
  LIVE
  FINISHED
  CANCELLED
}

model Fixture {
  id                  String        @id @default(cuid())
  competitionId       String
  roundId             String?       // Optional: linked to a CompetitionRound
  homeParticipantId   String
  awayParticipantId   String
  startsAt            DateTime
  result              Json?
  status              FixtureStatus @default(SCHEDULED)
  createdAt           DateTime      @default(now())

  competition      Competition      @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  round            CompetitionRound? @relation(fields: [roundId], references: [id], onDelete: SetNull)
  homeParticipant  Participant       @relation("HomeParticipant", fields: [homeParticipantId], references: [id])
  awayParticipant  Participant       @relation("AwayParticipant", fields: [awayParticipantId], references: [id])
  predictions      Prediction[]
}

model Prediction {
  id             String   @id @default(cuid())
  fixtureId      String
  userId         String
  prediction     Json
  pointsAwarded  Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fixture Fixture @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([fixtureId, userId])
}

model ScoringRule {
  id             String @id @default(cuid())
  competitionId  String
  ruleDefinition Json

  competition Competition @relation(fields: [competitionId], references: [id], onDelete: Cascade)
}

// ─── Special Questions (Spezialtipps) ─────────────────────────────────────────

enum SpecialQuestionType {
  SINGLE_PARTICIPANT    // Pick one participant (e.g. "Wer wird Weltmeister?")
  MULTIPLE_PARTICIPANTS // Pick N participants (e.g. "Wer kommt ins Halbfinale?")
  NUMBER               // Enter a number (e.g. "Wie viele 9-Darter?")
}

model SpecialQuestion {
  id                     String              @id @default(cuid())
  competitionId          String
  question               String
  description            String?             @db.Text
  type                   SpecialQuestionType
  points                 Int
  deadline               DateTime
  requiredCount          Int?                // For MULTIPLE_PARTICIPANTS: how many to pick
  usePercentageTolerance Boolean             @default(false) // For NUMBER: partial points
  correctAnswer          String?             // JSON: participant IDs or number
  isActive               Boolean             @default(true)
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt

  competition Competition    @relation(fields: [competitionId], references: [id], onDelete: Cascade)
  answers     SpecialAnswer[]
}

model SpecialAnswer {
  id                 String   @id @default(cuid())
  specialQuestionId  String
  userId             String
  answer             String   // JSON: participant ID(s) or number
  pointsAwarded      Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  specialQuestion    SpecialQuestion @relation(fields: [specialQuestionId], references: [id], onDelete: Cascade)
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Convenience relation for SINGLE_PARTICIPANT answers
  singleParticipantId String?
  singleParticipant   Participant?    @relation("SingleParticipantAnswer", fields: [singleParticipantId], references: [id])

  @@unique([specialQuestionId, userId])
}

// ─── Module 3: Darts League ────────────────────────────────────────────────────

model DartsLeague {
  id          String   @id @default(cuid())
  name        String
  kFactor     Int      @default(32)
  startingElo Int      @default(1000)
  matchConfig Json
  createdAt   DateTime @default(now())

  matches    DartsMatch[]
  members    DartsLeagueMember[]
  eloHistory EloHistory[]
}

model DartsLeagueMember {
  leagueId   String
  playerId   String
  currentElo Int      @default(1000)
  joinedAt   DateTime @default(now())

  league DartsLeague @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  player DartsPlayer @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@id([leagueId, playerId])
}

model DartsPlayer {
  id         String @id @default(cuid())
  userId     String @unique
  currentElo Int    @default(1000)

  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  eloHistory       EloHistory[]
  leagueMemberships DartsLeagueMember[]
}

enum ChallengeStatus {
  PENDING
  ACCEPTED
  COMPLETED
  DECLINED
  EXPIRED
}

model DartsChallenge {
  id           String          @id @default(cuid())
  challengerId String
  opponentId   String
  status       ChallengeStatus @default(PENDING)
  expiresAt    DateTime?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  challenger User        @relation("Challenger", fields: [challengerId], references: [id])
  opponent   User        @relation("Opponent", fields: [opponentId], references: [id])
  match      DartsMatch?
}

enum MatchStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  DISPUTED
}

model DartsMatch {
  id              String      @id @default(cuid())
  leagueId        String?
  challengeId     String?     @unique
  playerAId       String
  playerBId       String
  winnerId        String?
  matchConfig     Json
  playedAt        DateTime    @default(now())
  status          MatchStatus @default(PENDING_CONFIRMATION)
  submittedById   String?
  disputeReason   String?

  league    DartsLeague?    @relation(fields: [leagueId], references: [id])
  challenge DartsChallenge? @relation(fields: [challengeId], references: [id])
  playerA   User            @relation("PlayerA", fields: [playerAId], references: [id])
  playerB   User            @relation("PlayerB", fields: [playerBId], references: [id])
  winner    User?           @relation("Winner", fields: [winnerId], references: [id])
  submittedBy User?         @relation("MatchSubmitter", fields: [submittedById], references: [id])
  legs      DartsLeg[]
  eloHistory EloHistory[]
}

model DartsLeg {
  id        String @id @default(cuid())
  matchId   String
  legNumber Int
  winnerId  String?
  legData   Json?

  match DartsMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
}

model EloHistory {
  id           String   @id @default(cuid())
  playerId     String
  matchId      String
  leagueId     String?
  ratingBefore Int
  ratingAfter  Int
  createdAt    DateTime @default(now())

  player DartsPlayer  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  match  DartsMatch   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  league DartsLeague? @relation(fields: [leagueId], references: [id], onDelete: SetNull)
}

// ─── Module 4: Personal Management (Admin only) ───────────────────────────────

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

model Task {
  id             String       @id @default(cuid())
  title          String
  description    String?      @db.Text
  isRecurring    Boolean      @default(false)
  recurrenceRule String?
  nextDueDate    DateTime?
  priority       TaskPriority @default(MEDIUM)
  completed      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  completions TaskCompletion[]
}

model TaskCompletion {
  id          String   @id @default(cuid())
  taskId      String
  completedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  category  String?
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
